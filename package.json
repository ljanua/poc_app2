{
  "name": "poc_app-bdd",
  "version": "1.0.0",
  "private": true,
  "description": "BDD test runner for admin user management and auth-role flows",
  "dependencies": {
    "busboy": "^1.6.0",
    "dotenv": "^17.4.2",
    "pg": "^8.16.3"
  },
  "scripts": {
    "db:bootstrap": "node scripts/db-bootstrap.js",
    "build": "npm run build:solution",
    "build:solution": "npm run bdd:smoke",
    "serve:mockup": "node scripts/serve-mockup.js",
    "e2e:up": "npm run serve:mockup",
    "pw:test": "playwright test",
    "pw:test:s1": "playwright test tests/playwright/s1-player-list.spec.js",
    "bdd:smoke": "node scripts/bdd-smoke.js",
    "bdd:test": "npm run bdd:smoke && cucumber-js --config cucumber.json",
    "bdd:test:admin": "cucumber-js tests/bdd/features/admin-user-management.feature --require tests/bdd/features/step_definitions/**/*.js --require tests/bdd/features/support/**/*.js",
    "ci:e2e": "npx playwright install --with-deps && npx playwright test"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.0.0",
    "@playwright/test": "^1.53.0",
    "vitest": "^4.1.9"
  }
}
