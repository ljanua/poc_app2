# Copy to .env and fill in real values.

# PostgreSQL connection string for the API / mockup server.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# POC App (future app.vantagiq.com)
MOCKUP_HOST=0.0.0.0
MOCKUP_PORT=5500
APP_ORIGIN=http://127.0.0.1:5500

# Public site (future vantagiq.com)
PUBLIC_HOST=0.0.0.0
PUBLIC_PORT=5501
PUBLIC_ORIGIN=http://127.0.0.1:5501

# Signed access tokens (HMAC). Change in any shared environment.
JWT_SECRET=vantagiq-dev-jwt-secret-change-me

# OAuth: leave stub mode true for local/CI without provider apps.
OAUTH_STUB_MODE=true
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=

# Root folder for stored video originals, segments, and thumbnails.
# Falls back to the DEFAULT_VIDEO_ROOT constant in
# scripts/video-processing/config.js when unset.
VANTAGEIQ_VIDEO_ROOT=C:\vantageiq_videos

# Structured backend log file (mockup server + video processing).
# Loaded from .env by scripts/serve-mockup.js via dotenv.
# Precedence in scripts/logging/structured-logger.js:
#   STRUCTURED_LOG_PATH → VIDEO_PROCESSING_AUDIT_LOG_PATH (legacy) → log/backend_logging.txt
# Relative paths resolve from process.cwd(). Use an absolute path in production if needed.
STRUCTURED_LOG_PATH=log/backend_logging.txt
# STRUCTURED_LOG_PATH=C:\vantageiq_logs\backend_logging.txt

# Video processing: log full Ollama JSON responses to the structured audit log (local troubleshooting only).
DEBUG=false
